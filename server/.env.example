# Copy to .env and fill in real values. Never commit .env.

# --- App ---
DOMAIN=api.example.com
CORS_ORIGINS=https://www.youtube.com
HUGGINGFACE_MODEL=kayaaaa/ad-classifier-int8
CLASSIFIER_BACKEND=onnx
CLASSIFIER_BATCH_SIZE=32
NER_ENABLED=false

# --- Database ---
# docker-compose.yml sets DB_HOST=db and DB_PORT=3306 for the app container.
DB_USER=skipr
DB_PASSWORD=change-me
DB_NAME=skipr_db
MYSQL_ROOT_PASSWORD=change-me-root

# --- Optional ---
# LOG_LEVEL=INFO
# HF_TOKEN=hf_...
